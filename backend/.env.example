# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/krishi-sarthi?retryWrites=true&w=majority

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Your app secrets
JWT_SECRET=your_jwt_secret_key_here

# OpenWeatherMap API
API_KEY=your_openweathermap_api_key

# Server port
PORT=5000

# Hugging Face Inference API (plant disease image classification)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Hub model id (must be deployed on HF Inference). Default: linkanjarad/mobilenet_v2_1.0_224-plant-disease-identification
# HF_PLANT_DISEASE_MODEL=linkanjarad/mobilenet_v2_1.0_224-plant-disease-identification

DATA_GOV_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Exa (web search fallback for mandi rates + schemes)
EXA_API_KEY=your_key_here